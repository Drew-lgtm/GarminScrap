# Copy to .env and fill in. .env is gitignored — never commit it.

# Garmin Connect credentials (only used by the one-time `login` command)
GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=your-password
# Set true only for Garmin China accounts
GARMIN_IS_CN=false

# Where OAuth tokens are stored locally (gitignored)
GARMINTOKENS=tokens

# Where scraped JSON is written locally (gitignored)
DATA_DIR=data

# Storage backend: "local" (default) or "r2" (writes local AND uploads to Cloudflare R2)
STORAGE_BACKEND=local

# Cloudflare R2 (only needed when STORAGE_BACKEND=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PREFIX=garmin

# Optional AI report via the Claude API. Leave blank to skip the analyze step.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Automated MFA via Gmail API (read-only). From `python scripts/gmail_auth.py`.
# Leave blank to enter the code manually at login.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_OTP_QUERY=from:garmin newer_than:1d

# Weekly MD-style report: free Gemini API + Gmail SMTP email.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=
REPORT_TO=
# Where `report` reads data: local or r2 (default = STORAGE_BACKEND)
REPORT_SOURCE=
